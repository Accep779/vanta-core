# VANTA Core — Environment Configuration

# === Ollama Cloud (Primary LLM) ===
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=minimax-m2.7:cloud

# === Alternative Cloud Models ===
# MiniMax M2.7 (recommended - newest, best for agentic tasks)
# ollama cloud pull minimax-m2.7:cloud

# Kimi K2.5 (alternative - strong reasoning)
# ollama cloud pull kimi-k2.5:cloud

# Qwen3.5 (alternative - coding + general)
# ollama cloud pull qwen3.5:cloud

# GLM-5 (alternative - long-horizon reasoning)
# ollama cloud pull glm-5:cloud

# === Cloud Model Providers (Optional) ===
# Z.ai (GLM-5)
ZAI_API_KEY=your_zai_api_key_here

# Alibaba (Qwen3.5)
ALIBABA_API_KEY=your_alibaba_api_key_here

# NVIDIA (Nemotron-3-Super)
NVIDIA_API_KEY=your_nvidia_api_key_here

# === VANTA Core Configuration ===
VANTA_DEFAULT_MODEL=anthropic
VANTA_DEFAULT_MODEL_PROVIDER=anthropic
VANTA_DEFAULT_CLOUD_MODEL=qwen3.5

# Fallback settings
VANTA_CLOUD_FALLBACK=true
VANTA_LOCAL_MODEL=qwen3.5:local

# === Engagement Defaults ===
VANTA_MAX_ITERATIONS=20
VANTA_TEMPERATURE=0
VANTA_STOP_ON_GATE=false

# === Audit & Logging ===
VANTA_AUDIT_LEVEL=verbose
VANTA_LOG_FILE=logs/vanta-core.log

# === Test Configuration ===
TEST_DOMAIN=example.com
# Replace with your actual domain for E2E testing
